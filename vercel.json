{
  "buildCommand": "",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{"type": "host", "value": "klaverjas.vercel.app"}],
      "destination": "https://klaverjasscore.nl/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!sounds|assets|favicon|manifest|icons).*)", "destination": "/index.html" }
  ]
}
